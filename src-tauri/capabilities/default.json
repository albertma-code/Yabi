{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window and the Python sidecar.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "opener:allow-open-path",
    "opener:allow-reveal-item-in-dir",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        { "name": "binaries/bilio-sidecar", "sidecar": true }
      ]
    },
    "shell:allow-stdin-write"
  ]
}
